# ── Database ───
DATABASE_URL=postgresql+psycopg2://djps:djps@localhost:5432/djps

# ── Redis ───
REDIS_URL=redis://localhost:6379/0

# ── Job execution ───
# URL the worker GETs to simulate real work
SIMULATED_JOB_URL=https://httpbin.org/delay/1
# Fraction of jobs to fail deliberately (0.0 = never fail, 1.0 = always fail)
SIMULATED_FAILURE_RATE=0.2
# HTTP timeout for the simulated call (seconds)
SIMULATED_TIMEOUT=5.0

# ── Retry / backoff ──
# Maximum retry attempts before a job is moved to the Dead Letter Queue
MAX_JOB_RETRIES=3
# Exponential backoff base: delay = BACKOFF_BASE ** retry_count  (seconds)
BACKOFF_BASE=2.0
# Upper ceiling on backoff delay (seconds)
MAX_BACKOFF=60.0

# ── Worker ───
# Number of worker processes spawned by WorkerManager
NUM_WORKERS=2
# Redis key TTL for worker heartbeats (seconds)
WORKER_HEARTBEAT_TTL=30
# A job stuck in 'processing' longer than this is considered abandoned (seconds)
STUCK_JOB_THRESHOLD=60
# Run the stuck-job scan once every N worker loop cycles
STUCK_CHECK_INTERVAL=10